    "welcome": {
        "message": "Hi! I can help you explore protected areas and biodiversity data. Try asking:",
        "examples": [
            "Tell me about the datasets you have access to.",
            "Show species richness for amphibians.",
            "What are the protected areas in this region?",
            "Which areas have the highest biodiversity?"
        ]
    },
